# ===========================================
# Supabase（必須: 認証・DB 接続に使用）
# ===========================================
# 取得: Supabase ダッシュボード → プロジェクト選択 → Settings → API
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - Project API keys の "anon" "public" → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===========================================
# Supabase（オプション: ゲストリンク等で RLS をバイパスする場合）
# ===========================================
# 取得: 上記と同じ画面の "service_role" key（秘密鍵・サーバー専用）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===========================================
# OpenAI（オプション: Phase 1 の AI キャプション生成用）
# ===========================================
# 取得: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# App（オプション: メール内リンク・コールバック URL に使う場合）
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:50000
